# Shopify Storefront API (Public - for frontend)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token

# Shopify Admin API (Private - for server-side sync)
SHOPIFY_ADMIN_API_KEY=your-admin-api-key
SHOPIFY_ADMIN_API_SECRET=your-admin-api-secret
SHOPIFY_API_VERSION=2024-01

# Sync Secret (for authorizing sync API calls)
SYNC_SECRET=your-random-sync-secret-change-this

# OpenAI (for AI Search)
OPENAI_API_KEY=your-openai-api-key

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:3000

# Visma Integration Service
# Connect to the Visma microservice for ERP data sync
VISMA_SERVICE_URL=http://localhost:5001
VISMA_SERVICE_TOKEN=your-service-token-optional
VISMA_TENANT_ID=your-visma-tenant-id

# NOTE: Visma → Shopify sync runs in the backend service (port 5001)
# This Next.js app calls the Visma service API for sync operations
# See ARCHITECTURE.md and backend documentation for details
